---
import { PERSONAL } from '@/config/personal'
import Badge from '@/components/Badge.astro'
import LinkedInIcon from '@/components/icons/LinkedIn.astro'
import MailIcon from '@/components/icons/Mail.astro'
import Download from '@/components/icons/Download.astro'
import SocialPill from '@/components/SocialPill.astro'
import DownloadPill from '@/components/DownloadPill.astro'
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-6 items-center">
    <div class="relative">
      <span class="absolute inset-0 rounded-full animate-[spin_4s_linear_infinite] bg-[conic-gradient(from_0deg,#eab308,#facc15,#fde68a,#eab308)] blur-[2px] opacity-70"></span>
      <picture class="relative block rounded-full w-16 h-16 overflow-hidden ring-2 ring-yellow-400/60 shadow-lg shadow-yellow-500/20">
        <img
          class="w-full h-full object-cover rounded-full"
          src={PERSONAL.images.avatar}
          alt={`${PERSONAL.name} — ${PERSONAL.role}`}
          width="64"
          height="64"
        />
      </picture>
    </div>
    <a
      href={PERSONAL.social.linkedin}
      target="_blank"
      rel="noopener"
      class="flex items-center transition hover:scale-105"
    >
      <Badge>Disponible para trabajar</Badge>
    </a>
  </div>

  <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
    <span class="text-gray-800 dark:text-white">Hey, soy </span>
    <span class="bg-gradient-to-r from-yellow-500 via-yellow-400 to-amber-300 bg-clip-text text-transparent">{PERSONAL.nameShort}</span>
    <span class="text-gray-800 dark:text-white"> 👋</span>
  </h1>

  <p class="mt-6 text-xl leading-relaxed text-gray-700 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-600 [&>strong]:font-semibold dark:text-gray-300">
    +4 años de experiencia.
    <strong>{PERSONAL.role}</strong> de {PERSONAL.location}.
    Especializado en análisis de datos, diseño y desarrollo de sistemas de información.
  </p>

  <nav class="flex flex-wrap gap-3 mt-8">
    <SocialPill href={`mailto:${PERSONAL.email}`}>
      <MailIcon class="size-4 md:size-5" />
      Contáctame
    </SocialPill>
    <SocialPill href={PERSONAL.social.linkedin}>
      <LinkedInIcon class="size-4 md:size-5" />
      LinkedIn
    </SocialPill>
    <DownloadPill href={PERSONAL.cv} download>
      <Download class="size-4 md:size-5" />
      Currículum Vitae
    </DownloadPill>
  </nav>
</div>
