---
import { PROJECTS, TAGS } from '@/data/projects'
import GitHub from './icons/GitHub.astro'
import VueJS from './icons/VueJs.astro'
import Javascript from './icons/Javascript.astro'
import TypeScript from './icons/TypeScript.astro'
import React from './icons/React.astro'
import CSS from './icons/CSS.astro'
import Link from './icons/Link.astro'
import LinkButton from './LinkButton.astro'
import Tailwind from './icons/Tailwind.astro'
import NextJS from './icons/NextJS.astro'

const TAG_ICONS = {
  VUE: VueJS,
  TAILWIND: Tailwind,
  CSS: CSS,
  JAVASCRIPT: Javascript,
  TYPESCRIPT: TypeScript,
  REACT: React,
  NEXTJS: NextJS,
}
---

<div class="flex flex-col gap-y-20">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
      <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition-all duration-500 ease-in-out overflow-clip rounded-2xl border border-gray-200/60 dark:border-gray-700/60 shadow-md md:group-hover:shadow-yellow-500/10 md:group-hover:shadow-xl md:group-hover:-translate-y-2 md:group-hover:border-yellow-400/30">
            <img
              alt={title}
              class="object-cover object-top w-full h-56 sm:h-64 md:h-56 transition-all duration-500 md:scale-110 md:group-hover:scale-105 md:group-hover:brightness-105"
              loading="lazy"
              src={image}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 md:group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" />
          </div>
        </div>

        <div class="w-full md:w-1/2 md:max-w-lg flex flex-col justify-center">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100 group-hover:text-yellow-600 dark:group-hover:text-yellow-400 transition-colors duration-300">
            {title}
          </h3>
          <div class="flex flex-col mt-3 gap-3">
            <ul class="flex flex-row flex-wrap gap-2">
              {tags.map((tagKey) => {
                const tag = TAGS[tagKey]
                const Icon = TAG_ICONS[tagKey]
                return (
                  <li>
                    <span class={`flex items-center gap-x-1.5 rounded-full text-xs font-medium ${tag.class} py-1 px-2.5`}>
                      <Icon class="size-3.5" />
                      {tag.name}
                    </span>
                  </li>
                )
              })}
            </ul>

            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              {description}
            </p>

            <footer class="flex items-center justify-start mt-2 gap-x-3">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-5" />
                  Code
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  Preview
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    ))
  }
</div>
